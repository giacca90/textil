---
import '../../styles/global.css';
import {getCollection} from 'astro:content';
import {ClientRouter} from 'astro:transitions';
import uiDataRaw from './index.json';

type Lang = 'ca' | 'en' | 'fr';
interface UITranslations {
	title: string;
	search: string;
	details: string;
	more: string;
	empty: string;
}

const uiData = uiDataRaw as Record<Lang, UITranslations>;

export async function getStaticPaths() {
	return [{params: {lang: 'ca'}}, {params: {lang: 'en'}}, {params: {lang: 'fr'}}];
}

const {lang} = Astro.params as {lang: Lang};
const articulosDeEsteIdioma = await getCollection('articulos', ({data}) => data.lang === lang);

const t = uiData[lang];
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const homeUrl = `${baseUrl}/${lang}`;

const languages = [
	{code: 'es', label: 'Castellano', flag: 'https://upload.wikimedia.org/wikipedia/commons/9/9a/Flag_of_Spain.svg', path: '/'},
	{code: 'ca', label: 'Català', flag: 'https://upload.wikimedia.org/wikipedia/commons/c/ce/Flag_of_Catalonia.svg', path: '/ca'},
	{code: 'en', label: 'English', flag: 'https://upload.wikimedia.org/wikipedia/commons/a/a5/Flag_of_the_United_Kingdom_%281-2%29.svg', path: '/en'},
	{code: 'fr', label: 'Français', flag: 'https://upload.wikimedia.org/wikipedia/commons/c/c3/Flag_of_France.svg', path: '/fr'},
];
---

<html lang={lang}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>C. Palau S.A. | {t.title}</title>
		<ClientRouter />
	</head>
	<body class="bg-gray-50 dark:bg-gray-900 flex flex-col min-h-screen text-gray-900 dark:text-gray-100">
		<main class="mx-auto max-w-6xl px-4 py-12 grow">
			<header class="mb-12 flex flex-col md:flex-row justify-between items-center gap-6">
				<a href={homeUrl} class="text-4xl font-extrabold text-indigo-600 dark:text-indigo-400 hover:opacity-80 transition-opacity">C. PALAU SA</a>

				<nav class="flex gap-2 bg-white dark:bg-gray-800 p-1.5 rounded-full shadow-sm border border-gray-200 dark:border-gray-700">
					{
						languages.map((l) => (
							<a href={l.code === 'es' ? `${baseUrl}/` : `${baseUrl}${l.path}`} title={l.label} class={`w-8 h-8 rounded-full border-2 transition-all overflow-hidden ${l.code === (lang as string) ? 'border-indigo-500 scale-110' : 'border-transparent opacity-50 hover:opacity-100'}`}>
								<img src={l.flag} alt={l.label} class="w-full h-full object-cover shadow-inner" />
							</a>
						))
					}
				</nav>
			</header>

			<div class="mb-12 text-center">
				<h1 class="text-3xl font-bold mb-8 text-gray-800 dark:text-gray-200">{t.title}</h1>
				<input type="text" id="buscador" placeholder={t.search} class="w-full max-w-md mx-auto block rounded-2xl border border-gray-300 p-3 dark:bg-gray-800 dark:border-gray-700 focus:ring-2 focus:ring-indigo-500 outline-none transition-all shadow-sm dark:text-white" />
			</div>

			<div id="grid-articulos" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
				{
					articulosDeEsteIdioma.length > 0 ? (
						articulosDeEsteIdioma.map((art) => (
							<article data-nombre={art.data.nombre.toLowerCase()} class="card-articulo flex flex-col border rounded-xl overflow-hidden bg-white dark:bg-gray-800 shadow-sm hover:shadow-md transition-all dark:border-gray-700">
								<a href={`${baseUrl}/${lang}/articulo/${art.data.index}`} class="block overflow-hidden aspect-video bg-gray-200 dark:bg-gray-700">
									<img src={art.data.imagen} alt={art.data.nombre} class="object-cover w-full h-full hover:scale-105 transition-transform duration-500" loading="lazy" transition:name={`img-${art.data.index}`} />
								</a>
								<div class="p-6 flex flex-col grow">
									<h2 class="text-xl font-bold mb-2 capitalize">{art.data.nombre}</h2>
									<p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-3 mb-4">{art.data.descripcion}</p>
									<a href={`${baseUrl}/${lang}/articulo/${art.data.index}`} class="mt-auto block bg-indigo-600 text-white text-center py-2 rounded-lg font-medium hover:bg-indigo-700 transition-colors">
										{t.details}
									</a>
								</div>
							</article>
						))
					) : (
						<div class="col-span-full text-center py-20 italic text-gray-500">{t.empty}</div>
					)
				}
			</div>

			<div class="mt-12 text-center">
				<button id="btn-cargar-mas" class="bg-indigo-100 text-indigo-600 dark:bg-indigo-900/40 dark:text-indigo-300 px-8 py-3 rounded-full font-bold hover:bg-indigo-200 transition-all">{t.more}</button>
			</div>
			<div id="no-results" class="hidden py-20 text-center italic text-gray-500">{t.empty}</div>
		</main>

		<footer class="py-8 border-t border-gray-200 dark:border-gray-800 text-center">
			<p class="text-sm text-gray-500 mb-4">&copy; {new Date().getFullYear()} C. PALAU SA</p>
			<a href={`${baseUrl}/${lang}/nosotros`} class="text-sm font-medium text-indigo-600 hover:underline">{lang === 'en' ? 'About Us' : lang === 'fr' ? 'À Propos' : 'Sobre Nosaltres'}</a>
		</footer>

		<script>
			const setup = () => {
				const input = document.getElementById('buscador') as HTMLInputElement;
				const articles = Array.from(document.querySelectorAll('.card-articulo')) as HTMLElement[];
				const btn = document.getElementById('btn-cargar-mas') as HTMLButtonElement;
				const noRes = document.getElementById('no-results');

				if (!input) return;

				// --- SOLUCIÓN AL PLACEHOLDER ---
				// Al navegar, Astro inyecta el nuevo HTML. Extraemos el placeholder
				// del nuevo HTML y se lo aplicamos al elemento persistido.
				const currentPlaceholder = document.querySelector('input#buscador')?.getAttribute('placeholder');
				if (currentPlaceholder) {
					input.placeholder = currentPlaceholder;
				}

				// OPCIONAL: Limpiar el buscador al cambiar de idioma
				// input.value = '';

				let visible = 15;
				const render = () => {
					const term = input.value.toLowerCase() || '';
					const filtered = articles.filter((a) => a.dataset.nombre?.includes(term));

					articles.forEach((a) => a.classList.add('hidden'));
					filtered.slice(0, visible).forEach((a) => a.classList.remove('hidden'));

					if (btn) btn.style.display = visible >= filtered.length ? 'none' : 'inline-block';
					noRes?.classList.toggle('hidden', filtered.length > 0);
				};

				input.addEventListener('input', () => {
					visible = 15;
					render();
				});

				btn?.addEventListener('click', () => {
					visible += 15;
					render();
				});

				render();
			};

			// Se ejecuta en cada navegación de View Transitions
			document.addEventListener('astro:page-load', setup);
		</script>
	</body>
</html>
