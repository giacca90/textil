---
import {getCollection, type CollectionEntry} from 'astro:content';
import {ClientRouter} from 'astro:transitions';
import '../../../styles/global.css';

export async function getStaticPaths() {
	const articulos = await getCollection('articulos');

	// Filtramos para que este archivo SOLO genere rutas que tengan un idioma (no el principal si es español)
	// O si quieres que todos pasen por aquí, asegúrate de que el catálogo apunte a /es/...
	return articulos.map((art: CollectionEntry<'articulos'>) => ({
		params: {
			lang: art.data.lang, // Esto pondrá 'ca', 'en', 'fr' o 'es'
			id: art.data.index.toString(),
		},
		props: {art},
	}));
}

const {art} = Astro.props;
const {lang} = Astro.params;

const ui = {
	es: {back: 'Volver al catálogo', label: 'Colección de Tejidos', about: 'Sobre este artículo', call: 'Llamar ahora', defaultDesc: 'Este tejido es parte de nuestra selección exclusiva.'},
	ca: {back: 'Tornar al catàleg', label: 'Col·lecció de Teixits', about: 'Sobre aquest article', call: 'Trucar ara', defaultDesc: 'Aquest teixit és part de la nostra selecció exclusiva.'},
	en: {back: 'Back to catalog', label: 'Fabric Collection', about: 'About this item', call: 'Call now', defaultDesc: 'This fabric is part of our exclusive selection.'},
	fr: {back: 'Retour au catalogue', label: 'Collection de Tissus', about: 'À propos de cet article', call: 'Appeler maintenant', defaultDesc: 'Ce tissu fait partie de notre sélection exclusive.'},
};

const t = ui[lang as keyof typeof ui] || ui.es;

// Lógica de URL de retorno mejorada
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const backUrl = lang === 'es' ? `${baseUrl}/` : `${baseUrl}/${lang}/`;
---

<html lang={lang}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{art.data.nombre} | C. Palau S.A.</title>
		<ClientRouter />
	</head>
	<body class="bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 font-sans transition-colors duration-300">
		<main class="max-w-3xl mx-auto px-4 py-12">
			<a href={backUrl} class="group mb-8 inline-flex items-center text-indigo-600 dark:text-indigo-400 hover:text-indigo-800 dark:hover:text-indigo-300 transition-colors font-medium">
				<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
				</svg>
				{t.back}
			</a>

			<article class="bg-white dark:bg-gray-800 rounded-3xl shadow-xl border border-gray-100 dark:border-gray-700 overflow-hidden">
				<div class="w-full h-64 md:h-80 overflow-hidden bg-gray-200 dark:bg-gray-700">
					<img src={art.data.imagen} alt={art.data.nombre} class="w-full h-full object-cover" transition:name={`img-${art.data.index}`} />
				</div>

				<div class="px-8 pb-12 -mt-8 relative z-10">
					<div class="bg-white dark:bg-gray-800 rounded-2xl p-8 shadow-lg border border-gray-50 dark:border-gray-700">
						<span class="text-indigo-500 dark:text-indigo-400 font-bold uppercase tracking-widest text-xs">
							{t.label} (REF: #{art.data.index})
						</span>

						<h1 class="text-4xl md:text-5xl font-black text-gray-900 dark:text-white mt-2 mb-6 capitalize">
							{art.data.nombre}
						</h1>

						<div class="prose dark:prose-invert max-w-none mb-10">
							<h3 class="text-lg font-semibold text-gray-800 dark:text-gray-200 mb-2 underline decoration-indigo-200 dark:decoration-indigo-900 underline-offset-4">
								{t.about}
							</h3>
							<p class="text-gray-600 dark:text-gray-400 text-xl leading-relaxed whitespace-pre-line">
								{art.data.descripcion || t.defaultDesc}
							</p>
						</div>

						<div class="pt-8 border-t border-gray-100 dark:border-gray-700">
							<a href="tel:676317192" class="inline-flex items-center justify-center w-full bg-green-600 dark:bg-green-700 text-white px-8 py-4 rounded-xl font-bold hover:bg-green-700 dark:hover:bg-green-600 transition-all shadow-lg shadow-green-100 dark:shadow-none active:scale-95 text-lg">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
								</svg>
								{t.call}: 676 317 192
							</a>
						</div>
					</div>
				</div>
			</article>
		</main>
	</body>
</html>
