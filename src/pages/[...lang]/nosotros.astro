---
import '../../styles/global.css';
import {ClientRouter} from 'astro:transitions';
import uiDataRaw from './nosotros.json';

// 1. TIPADO ESTRICTO
type LangCode = 'es' | 'ca' | 'en' | 'fr';

interface NosotrosTranslations {
	title: string;
	description: string;
	navBack: string;
	headerTitle: string;
	headerSub: string;
	sedeTitle: string;
	sedeText: string;
	expTitle: string;
	expText: string;
	compTitle: string;
	compText: string;
	sumTitle: string;
	sumText: string;
}

const uiData = uiDataRaw as Record<LangCode, NosotrosTranslations>;

// 2. GENERACIÓN DE RUTAS DINÁMICAS
export async function getStaticPaths() {
	return [
		{params: {lang: undefined}}, // /nosotros (Español)
		{params: {lang: 'ca'}}, // /ca/nosotros
		{params: {lang: 'en'}}, // /en/nosotros
		{params: {lang: 'fr'}}, // /fr/nosotros
	];
}

// 3. LÓGICA DE IDIOMA Y RUTAS
const {lang} = Astro.params;
const currentLang: LangCode = (lang as LangCode) || 'es';
const t = uiData[currentLang];

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');

// Ruta de retorno al catálogo según el idioma
const backUrl = currentLang === 'es' ? `${baseUrl}/` : `${baseUrl}/${currentLang}/`;

// Formateo de negritas
const formatText = (text: string) => text.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
---

<html lang={currentLang}>
	<head>
		<meta charset="utf-8" />
		<style is:inline>
			/* ESTILOS CRÍTICOS INMEDIATOS */
			.rounded-3xl,
			.rounded-3xl img {
				border-radius: 1.5rem !important;
				overflow: hidden !important;
			}
			.rounded-2xl {
				border-radius: 1rem !important;
				overflow: hidden !important;
			}
			.rounded-xl {
				border-radius: 0.75rem !important;
				overflow: hidden !important;
			}
			.rounded-lg {
				border-radius: 0.5rem !important;
				overflow: hidden !important;
			}
			.rounded-full {
				border-radius: 9999px !important;
				overflow: hidden !important;
			}
			.dark {
				background-color: #111827 !important;
			}
			.dark body {
				background-color: #111827 !important;
			}
			::view-transition-old(*),
			::view-transition-new(*),
			::view-transition-group(*) {
				border-radius: inherit !important;
				overflow: hidden !important;
			}
		</style>
		<link rel="icon" type="image/x-icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
		<meta name="viewport" content="width=device-width" />
		<title>{t.title} | C. PALAU SA</title>
		<meta name="description" content={t.description} />
		<ClientRouter fallback="swap" />

		<script>
			if ('serviceWorker' in navigator) {
				window.addEventListener('load', () => {
					navigator.serviceWorker.register(`${import.meta.env.BASE_URL}sw.js`);
				});
			}
		</script>

		<script is:inline>
			if ('scrollRestoration' in history) {
				history.scrollRestoration = 'manual';
			}
			// El tema se aplica de forma inmediata
			(function () {
				const applyTheme = () => {
					const stored = localStorage.getItem('theme');
					const darkMode = stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches);
					document.documentElement.classList.toggle('dark', darkMode);
				};
				applyTheme();
				document.addEventListener('astro:after-swap', applyTheme);

				window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
					if (!localStorage.getItem('theme')) {
						document.documentElement.classList.toggle('dark', e.matches);
					}
				});
			})();
		</script>

		<style is:global>
			/* Optimizamos para que las transiciones sean suaves */
			::view-transition-old(*),
			::view-transition-new(*) {
				border-radius: inherit !important;
				overflow: hidden !important;
			}
		</style>
	</head>
	<body class="bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 font-sans transition-colors duration-300">
		<nav class="sticky top-0 z-50 border-b border-gray-200 bg-white/80 backdrop-blur-md dark:border-gray-800 dark:bg-gray-950/80">
			<div class="mx-auto max-w-6xl px-4 py-4 flex justify-between items-center w-full">
				<a href={backUrl} class="text-xl font-bold text-indigo-600 dark:text-indigo-400 hover:opacity-80 transition-opacity">C. PALAU SA</a>
				<a href={backUrl} class="text-sm font-medium hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors flex items-center gap-1">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
					</svg>
					{t.navBack}
				</a>
			</div>
		</nav>

		<main class="mx-auto max-w-4xl px-4 py-16 grow">
			<header class="mb-12 text-center">
				<h1 class="mb-4 text-5xl font-extrabold tracking-tight text-gray-900 dark:text-white" transition:name="page-title">{t.headerTitle}</h1>
				<p class="text-xl text-gray-600 dark:text-gray-400">{t.headerSub}</p>
			</header>

			<section class="space-y-12 text-lg leading-relaxed">
				<div class="section-card rounded-2xl bg-white p-8 shadow-sm border border-gray-100 dark:bg-gray-800 dark:border-gray-700">
					<h2 class="text-2xl font-bold mb-4 text-indigo-600 dark:text-indigo-400">{t.sedeTitle}</h2>
					<p set:html={formatText(t.sedeText)} />
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
					<div class="section-card rounded-2xl p-6 border-l-4 border-indigo-500 bg-white shadow-sm dark:bg-gray-800 border border-gray-100 dark:border-gray-700">
						<h3 class="font-bold text-xl mb-2">{t.expTitle}</h3>
						<p class="text-gray-600 dark:text-gray-400 text-base">{t.expText}</p>
					</div>
					<div class="section-card rounded-2xl p-6 border-l-4 border-indigo-500 bg-white shadow-sm dark:bg-gray-800 border border-gray-100 dark:border-gray-700">
						<h3 class="font-bold text-xl mb-2">{t.compTitle}</h3>
						<p class="text-gray-600 dark:text-gray-400 text-base">{t.compText}</p>
					</div>
				</div>

				<article class="section-card prose prose-indigo dark:prose-invert max-w-none bg-indigo-50/30 dark:bg-indigo-900/10 p-8 rounded-2xl border border-indigo-100 dark:border-indigo-900/30">
					<h3 class="text-indigo-900 dark:text-indigo-300 font-bold text-xl mb-4">{t.sumTitle}</h3>
					<p>{t.sumText}</p>
				</article>
			</section>
		</main>

		<footer class="mt-20 border-t border-gray-200 bg-white py-12 dark:border-gray-800 dark:bg-gray-950 text-center">
			<p class="text-sm text-gray-500">&copy; {new Date().getFullYear()} C. PALAU SA - La Roca del Vallès</p>
		</footer>
	</body>
</html>
