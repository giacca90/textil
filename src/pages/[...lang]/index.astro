---
import '../../styles/global.css';
import {ClientRouter} from 'astro:transitions';
import {getCollection} from 'astro:content';

type LangCode = 'es' | 'ca' | 'en' | 'fr';

const uiTranslations = {
	es: {title: 'Nuestros Productos', search: 'Buscar tejido...', details: 'Ver detalles', more: 'Cargar más productos', empty: 'No se encontraron tejidos.'},
	ca: {title: 'Els Nostres Productes', search: 'Cercar teixit...', details: 'Veure detalls', more: 'Carregar más productes', empty: "No s'han trobat teixits."},
	en: {title: 'Our Products', search: 'Search fabric...', details: 'View details', more: 'Load more products', empty: 'No fabrics found.'},
	fr: {title: 'Nos Produits', search: 'Chercher du tissu...', details: 'Voir les detalles', more: 'Charger plus de productos', empty: 'Aucun tissu trouvé.'},
};

export async function getStaticPaths() {
	return [{params: {lang: undefined}}, {params: {lang: 'ca'}}, {params: {lang: 'en'}}, {params: {lang: 'fr'}}];
}

const {lang} = Astro.params;
const currentLang = (lang as LangCode) || 'es';
const t = uiTranslations[currentLang];

const articulos = (await getCollection('articulos')).filter((a) => a.data.lang === currentLang);

// Lógica de rutas blindada para GitHub Pages (/textil/)
const base = import.meta.env.BASE_URL; // Ya incluye las barras: "/textil/"
const forceSlash = (path: string) => (path.endsWith('/') ? path : `${path}/`);

const getRoute = (l: LangCode) => {
	if (l === 'es') return base;
	return forceSlash(`${base}${l}`);
};

const homeUrl = getRoute(currentLang);

const languages = [
	{code: 'es', label: 'Castellano', flag: 'https://upload.wikimedia.org/wikipedia/commons/9/9a/Flag_of_Spain.svg'},
	{code: 'ca', label: 'Català', flag: 'https://upload.wikimedia.org/wikipedia/commons/c/ce/Flag_of_Catalonia.svg'},
	{code: 'en', label: 'English', flag: 'https://upload.wikimedia.org/wikipedia/commons/a/a5/Flag_of_the_United_Kingdom_%281-2%29.svg'},
	{code: 'fr', label: 'Français', flag: 'https://upload.wikimedia.org/wikipedia/commons/c/c3/Flag_of_France.svg'},
];
---

<html lang={currentLang}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>C Palau S.A. | Mayorista</title>

		<link rel="icon" type="image/svg+xml" href={`${base}favicon.ico`} />

		<ClientRouter />

		<script is:inline>
			// Forzar manual para controlar nosotros el salto tras el scroll-pos guardado
			if ('scrollRestoration' in history) history.scrollRestoration = 'manual';

			if (window.performance && window.performance.navigation.type === 1) {
				sessionStorage.clear();
			}
		</script>

		<style is:global>
			[transition:name] {
				will-change: transform, opacity;
			}
			html {
				scroll-behavior: auto !important;
			}
			.hidden-art {
				display: none !important;
			}
		</style>
	</head>
	<body class="bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 min-h-screen flex flex-col">
		<main class="mx-auto max-w-6xl px-4 py-12 grow w-full">
			<header class="mb-12 flex justify-between items-center">
				<a href={homeUrl} class="text-3xl font-black text-indigo-600 dark:text-indigo-400">C. PALAU SA</a>
				<nav class="flex gap-2 bg-white dark:bg-gray-800 p-1 rounded-full shadow-sm border border-gray-200 dark:border-gray-700">
					{
						languages.map((l) => (
							<a href={getRoute(l.code as LangCode)} class={`w-8 h-8 rounded-full overflow-hidden border-2 ${l.code === currentLang ? 'border-indigo-500' : 'border-transparent opacity-50'}`}>
								<img src={l.flag} alt={l.label} class="w-full h-full object-cover" />
							</a>
						))
					}
				</nav>
			</header>

			<div class="mb-12 text-center">
				<h1 class="text-3xl font-bold mb-6">{t.title}</h1>
				<input type="text" id="buscador" placeholder={t.search} class="w-full max-w-md mx-auto block rounded-2xl border border-gray-300 p-3 dark:bg-gray-800 dark:border-gray-700 focus:ring-2 focus:ring-indigo-500 outline-none dark:text-white" />
			</div>

			<div id="grid-articulos" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
				{
					articulos.map((art) => (
						<article data-nombre={art.data.nombre.toLowerCase()} class="card-articulo flex flex-col border rounded-xl overflow-hidden bg-white dark:bg-gray-800 dark:border-gray-700">
							<a href={forceSlash(`${homeUrl}articulo/${art.data.index}`)} class="block aspect-video overflow-hidden bg-gray-100">
								<img src={art.data.imagen} alt={art.data.nombre} class="w-full h-full object-cover" transition:name={`img-${art.data.index}`} loading="eager" />
							</a>
							<div class="p-6 flex flex-col grow">
								<h2 class="text-xl font-bold mb-2 capitalize" transition:name={`nombre-${art.data.index}`}>
									{art.data.nombre}
								</h2>
								<p class="text-sm text-gray-500 line-clamp-3 mb-4">{art.data.descripcion}</p>
								<a href={forceSlash(`${homeUrl}articulo/${art.data.index}`)} class="mt-auto block bg-indigo-600 text-white text-center py-2 rounded-lg font-medium">
									{t.details}
								</a>
							</div>
						</article>
					))
				}
			</div>

			<div class="mt-12 text-center">
				<button id="btn-cargar-mas" class="bg-indigo-100 text-indigo-600 px-8 py-3 rounded-full font-bold">{t.more}</button>
			</div>
			<div id="no-results" class="hidden py-20 text-center italic text-gray-400">{t.empty}</div>
		</main>

		<script>
			const updateGrid = () => {
				const input = document.getElementById('buscador') as HTMLInputElement;
				const articles = Array.from(document.querySelectorAll('.card-articulo')) as HTMLElement[];
				const btn = document.getElementById('btn-cargar-mas');
				const noResults = document.getElementById('no-results');

				if (!input) return;

				const term = (sessionStorage.getItem('search-term') || '').toLowerCase().trim();
				const visibleCount = parseInt(sessionStorage.getItem('visible-count') || '15');

				input.value = term;

				let visibleActual = 0;
				articles.forEach((art) => {
					const nombre = art.dataset.nombre || '';
					const coincide = nombre.includes(term);

					if (coincide && visibleActual < visibleCount) {
						art.classList.remove('hidden-art');
						visibleActual++;
					} else {
						art.classList.add('hidden-art');
					}
				});

				const totalCoincidentes = articles.filter((a) => (a.dataset.nombre || '').includes(term)).length;
				if (btn) btn.style.display = visibleActual >= totalCoincidentes ? 'none' : 'inline-block';
				if (noResults) noResults.style.display = totalCoincidentes === 0 ? 'block' : 'none';
			};

			const init = () => {
				const input = document.getElementById('buscador') as HTMLInputElement;
				const btn = document.getElementById('btn-cargar-mas');
				const grid = document.getElementById('grid-articulos');

				if (!input) return;

				updateGrid();

				const vienesDeDetalle = sessionStorage.getItem('nav-from-detail') === 'true';
				if (vienesDeDetalle) {
					const savedScroll = sessionStorage.getItem('scroll-pos');
					if (savedScroll) {
						// Esperar un frame para que el grid se oculte/muestre según sessionStorage
						requestAnimationFrame(() => {
							window.scrollTo(0, parseInt(savedScroll));
						});
					}
					sessionStorage.removeItem('nav-from-detail');
				}

				input.oninput = () => {
					sessionStorage.setItem('search-term', input.value);
					sessionStorage.setItem('visible-count', '15');
					updateGrid();
				};

				if (btn) {
					btn.onclick = () => {
						const current = parseInt(sessionStorage.getItem('visible-count') || '15');
						sessionStorage.setItem('visible-count', (current + 15).toString());
						updateGrid();
					};
				}

				grid?.addEventListener('click', (e) => {
					const link = (e.target as HTMLElement).closest('a');
					if (link) {
						sessionStorage.setItem('nav-from-detail', 'true');
						sessionStorage.setItem('scroll-pos', window.scrollY.toString());
					}
				});
			};

			document.addEventListener('astro:page-load', init);
			document.addEventListener('astro:after-swap', updateGrid);
		</script>
	</body>
</html>
