---
import '../../styles/global.css';
import {ClientRouter} from 'astro:transitions';
import {getCollection} from 'astro:content';

type LangCode = 'es' | 'ca' | 'en' | 'fr';

const uiTranslations = {
	es: {title: 'Nuestros Productos', search: 'Buscar tejido...', details: 'Ver detalles', more: 'Cargar más productos', empty: 'No se encontraron tejidos.', footer: '© 2024 C. PALAU SA.', about: 'Nosotros'},
	ca: {title: 'Els Nostres Productes', search: 'Cercar teixit...', details: 'Veure detalls', more: 'Carregar más productes', empty: "No s'han trobat teixits.", footer: '© 2024 C. PALAU SA.', about: 'Nosaltres'},
	en: {title: 'Our Products', search: 'Search fabric...', details: 'View details', more: 'Load more products', empty: 'No fabrics found.', footer: '© 2024 C. PALAU SA.', about: 'About Us'},
	fr: {title: 'Nos Produits', search: 'Chercher du tissu...', details: 'Voir les detalles', more: 'Charger plus de productos', empty: 'Aucun tissu trouvé.', footer: '© 2024 C. PALAU SA.', about: 'À propos'},
};

export async function getStaticPaths() {
	return [{params: {lang: undefined}}, {params: {lang: 'ca'}}, {params: {lang: 'en'}}, {params: {lang: 'fr'}}];
}

const {lang} = Astro.params;
const currentLang = (lang as LangCode) || 'es';
const t = uiTranslations[currentLang];

const articulos = (await getCollection('articulos')).filter((a) => a.data.lang === currentLang);

const base = import.meta.env.BASE_URL;
const forceSlash = (path: string) => (path.endsWith('/') ? path : `${path}/`);

const getRoute = (l: LangCode) => {
	if (l === 'es') return base;
	return forceSlash(`${base}${l}`);
};

const homeUrl = getRoute(currentLang);
const aboutUrl = forceSlash(`${homeUrl}nosotros`);

const languages = [
	{code: 'es', label: 'Castellano', flag: 'https://upload.wikimedia.org/wikipedia/commons/9/9a/Flag_of_Spain.svg'},
	{code: 'ca', label: 'Català', flag: 'https://upload.wikimedia.org/wikipedia/commons/c/ce/Flag_of_Catalonia.svg'},
	{code: 'en', label: 'English', flag: 'https://upload.wikimedia.org/wikipedia/commons/a/a5/Flag_of_the_United_Kingdom_%281-2%29.svg'},
	{code: 'fr', label: 'Français', flag: 'https://upload.wikimedia.org/wikipedia/commons/c/c3/Flag_of_France.svg'},
];
---

<html lang={currentLang}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>C Palau S.A. | Mayorista</title>
		<link rel="icon" type="image/svg+xml" href={`${base}favicon.ico`} />
		<ClientRouter />

		<script is:inline>
			// El tema se aplica de forma inmediata para evitar destellos blancos
			const applyTheme = () => {
				const stored = localStorage.getItem('theme');
				const darkMode = stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches);
				document.documentElement.classList.toggle('dark', darkMode);
			};
			applyTheme();
			document.addEventListener('astro:after-swap', applyTheme);
		</script>

		<style is:global>
			/* Optimizamos para que las transiciones sean suaves */
			::view-transition-old(*),
			::view-transition-new(*) {
				animation-duration: 400ms;
			}
			.hidden-art {
				display: none !important;
			}
		</style>
	</head>
	<body class="bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 min-h-screen flex flex-col">
		<main class="mx-auto max-w-6xl px-4 py-12 grow w-full">
			<header class="mb-12 flex justify-between items-center">
				<a href={homeUrl} class="text-3xl font-black text-indigo-600 dark:text-indigo-400">C. PALAU SA</a>
				<nav class="flex gap-2 bg-white dark:bg-gray-800 p-1 rounded-full shadow-sm border border-gray-200 dark:border-gray-700">
					{
						languages.map((l) => (
							<a href={getRoute(l.code as LangCode)} class={`w-8 h-8 rounded-full overflow-hidden border-2 ${l.code === currentLang ? 'border-indigo-500' : 'border-transparent opacity-50'}`}>
								<img src={l.flag} alt={l.label} class="w-full h-full object-cover" />
							</a>
						))
					}
				</nav>
			</header>

			<div class="mb-12 text-center">
				<h1 class="text-3xl font-bold mb-6">{t.title}</h1>
				<input type="text" id="buscador" placeholder={t.search} class="w-full max-w-md mx-auto block rounded-2xl border border-gray-300 p-3 dark:bg-gray-800 dark:border-gray-700 focus:ring-2 focus:ring-indigo-500 outline-none dark:text-white" />
			</div>

			<div id="grid-articulos" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
				{
					articulos.map((art) => (
						<article data-nombre={art.data.nombre.toLowerCase()} class="card-articulo flex flex-col border rounded-xl overflow-hidden bg-white dark:bg-gray-800 dark:border-gray-700">
							<a href={forceSlash(`${homeUrl}articulo/${art.data.index}`)} class="block aspect-video overflow-hidden bg-gray-100">
								<img src={art.data.imagen} alt={art.data.nombre} class="w-full h-full object-cover" transition:name={`img-${art.data.index}`} />
							</a>
							<div class="p-6 flex flex-col grow">
								<h2 class="text-xl font-bold mb-2 capitalize" transition:name={`nombre-${art.data.index}`}>
									{art.data.nombre}
								</h2>
								<p class="text-sm text-gray-500 line-clamp-3 mb-4">{art.data.descripcion}</p>
								<a href={forceSlash(`${homeUrl}articulo/${art.data.index}`)} class="mt-auto block bg-indigo-600 text-white text-center py-2 rounded-lg font-medium">
									{t.details}
								</a>
							</div>
						</article>
					))
				}
			</div>

			<div class="mt-12 text-center">
				<button id="btn-cargar-mas" class="bg-indigo-100 text-indigo-600 px-8 py-3 rounded-full font-bold">{t.more}</button>
			</div>
			<div id="no-results" class="hidden py-20 text-center italic text-gray-400">{t.empty}</div>
		</main>

		<footer class="border-t border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900/50 backdrop-blur-sm">
			<div class="mx-auto max-w-6xl px-4 py-10">
				<div class="flex flex-col md:flex-row justify-between items-center gap-6">
					<div class="text-center md:text-left">
						<p class="font-bold text-gray-900 dark:text-white mb-1">C. PALAU SA</p>
						<p class="text-sm text-gray-500">{t.footer}</p>
					</div>
					<div class="flex items-center gap-6">
						<button id="theme-toggle" class="p-2 rounded-xl bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 hover:scale-110 transition-transform">
							<span class="dark:hidden">🌙</span>
							<span class="hidden dark:inline">☀️</span>
						</button>
						<a href={aboutUrl} class="text-sm font-medium hover:text-indigo-500 transition-colors">{t.about}</a>
					</div>
				</div>
			</div>
		</footer>

		<script>
			const prepareGrid = () => {
				const input = document.getElementById('buscador') as HTMLInputElement;
				const articles = Array.from(document.querySelectorAll('.card-articulo')) as HTMLElement[];
				const btn = document.getElementById('btn-cargar-mas');
				const noResults = document.getElementById('no-results');

				if (!input || articles.length === 0) return;

				const term = (sessionStorage.getItem('search-term') || '').toLowerCase().trim();
				const visibleCount = parseInt(sessionStorage.getItem('visible-count') || '15');
				input.value = term;

				let visibleActual = 0;
				articles.forEach((art) => {
					const coincide = (art.dataset.nombre || '').includes(term);
					if (coincide && visibleActual < visibleCount) {
						art.classList.remove('hidden-art');
						visibleActual++;
					} else {
						art.classList.add('hidden-art');
					}
				});

				const total = articles.filter((a) => (a.dataset.nombre || '').includes(term)).length;
				if (btn) btn.style.display = visibleActual >= total ? 'none' : 'inline-block';
				if (noResults) noResults.style.display = total === 0 ? 'block' : 'none';
			};

			const init = () => {
				const input = document.getElementById('buscador') as HTMLInputElement;
				const btn = document.getElementById('btn-cargar-mas');
				const isIndex = !!document.getElementById('grid-articulos');

				if (input) {
					input.oninput = () => {
						sessionStorage.setItem('search-term', input.value);
						sessionStorage.setItem('visible-count', '15');
						prepareGrid();
					};
				}

				if (btn) {
					btn.onclick = () => {
						const current = parseInt(sessionStorage.getItem('visible-count') || '15');
						sessionStorage.setItem('visible-count', (current + 15).toString());
						prepareGrid();
					};
				}

				// Restauramos scroll solo al volver
				if (isIndex && sessionStorage.getItem('should-restore') === 'true') {
					const pos = sessionStorage.getItem('scroll-pos');
					if (pos) window.scrollTo(0, parseInt(pos));
					sessionStorage.removeItem('should-restore');
				}
			};

			// Guardado de posición ANTES de navegar
			document.addEventListener('astro:before-preparation', () => {
				if (document.getElementById('grid-articulos')) {
					sessionStorage.setItem('scroll-pos', window.scrollY.toString());
				}
			});

			// Marcamos que queremos restaurar solo si hacemos click en "atrás" o volvemos al index
			document.addEventListener('click', (e) => {
				const target = e.target as HTMLElement;
				if (target.closest('#theme-toggle')) {
					const isDark = document.documentElement.classList.toggle('dark');
					localStorage.setItem('theme', isDark ? 'dark' : 'light');
				}
				if (target.closest('.card-articulo a')) {
					sessionStorage.setItem('should-restore', 'true');
				}
			});

			// Flujo de Astro
			prepareGrid();
			document.addEventListener('astro:after-swap', prepareGrid);
			document.addEventListener('astro:page-load', init);
		</script>
	</body>
</html>
