---
import {getCollection, type CollectionEntry} from 'astro:content';
import {ClientRouter} from 'astro:transitions';
import '../../../styles/global.css';
import uiDataRaw from './id.json';

type LangCode = 'es' | 'ca' | 'en' | 'fr';

interface DetalleTranslations {
	back: string;
	label: string;
	about: string;
	call: string;
	defaultDesc: string;
}

const uiData = uiDataRaw as Record<LangCode, DetalleTranslations>;

export async function getStaticPaths() {
	const articulos = await getCollection('articulos');

	return articulos.map((art: CollectionEntry<'articulos'>) => {
		// Importante: langParam debe coincidir exactamente con el del index
		const langParam = art.data.lang === 'es' ? undefined : art.data.lang;

		return {
			params: {
				lang: langParam,
				id: art.data.index.toString(),
			},
			props: {art},
		};
	});
}

const {art} = Astro.props;
const {lang} = Astro.params;
const currentLang: LangCode = (lang as LangCode) || 'es';

const t = uiData[currentLang];

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
// Asegúrate de que esta URL sea idéntica a la que el index espera recibir
const backUrl = currentLang === 'es' ? `${baseUrl}/` : `${baseUrl}/${currentLang}/`;
---

<html lang={currentLang}>
	<head>
		<meta charset="utf-8" />
		<style is:inline>
			/* ESTILOS CRÍTICOS INMEDIATOS */
			.rounded-3xl,
			.main-card,
			.main-card img {
				border-radius: 1.5rem !important;
				overflow: hidden !important;
			}
			.rounded-2xl,
			.inner-card {
				border-radius: 1rem !important;
				overflow: hidden !important;
			}
			.rounded-xl {
				border-radius: 0.75rem !important;
				overflow: hidden !important;
			}
			.rounded-lg {
				border-radius: 0.5rem !important;
				overflow: hidden !important;
			}
			.dark {
				background-color: #111827 !important;
			}
			.dark body {
				background-color: #111827 !important;
			}
			/* Transiciones */
			::view-transition-old(*),
			::view-transition-new(*),
			::view-transition-group(*) {
				border-radius: inherit !important;
				overflow: hidden !important;
			}
		</style>
		<meta name="viewport" content="width=device-width" />
		<title>{art.data.nombre} | C. Palau S.A. | Mayorista Textil</title>
		<meta name="description" content={art.data.descripcion || t.defaultDesc} />
		<meta name="keywords" content={`${art.data.nombre}, textil, mayorista, tejidos, telas, C. Palau, Barcelona`} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="article" />
		<meta property="og:url" content={`https://giacca90.github.io/textil/${currentLang === 'es' ? '' : currentLang + '/'}articulo/${art.data.index}/`} />
		<meta property="og:title" content={`${art.data.nombre} | C. Palau S.A.`} />
		<meta property="og:description" content={art.data.descripcion || t.defaultDesc} />
		<meta property="og:image" content={art.data.imagen} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={`https://giacca90.github.io/textil/${currentLang === 'es' ? '' : currentLang + '/'}articulo/${art.data.index}/`} />
		<meta property="twitter:title" content={`${art.data.nombre} | C. Palau S.A.`} />
		<meta property="twitter:description" content={art.data.descripcion || t.defaultDesc} />
		<meta property="twitter:image" content={art.data.imagen} />

		<link rel="icon" type="image/x-icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
		<ClientRouter fallback="swap" />

		<script>
			if ('serviceWorker' in navigator) {
				window.addEventListener('load', () => {
					navigator.serviceWorker.register(`${import.meta.env.BASE_URL}sw.js`);
				});
			}
		</script>

		<script is:inline>
			if ('scrollRestoration' in history) {
				history.scrollRestoration = 'manual';
			}
			// El tema se aplica de forma inmediata
			(function () {
				const applyTheme = () => {
					const stored = localStorage.getItem('theme');
					const darkMode = stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches);
					document.documentElement.classList.toggle('dark', darkMode);
				};
				applyTheme();
				document.addEventListener('astro:after-swap', applyTheme);

				window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
					if (!localStorage.getItem('theme')) {
						document.documentElement.classList.toggle('dark', e.matches);
					}
				});
			})();
		</script>
		<style is:global>
			/* Optimizamos para que las transiciones sean suaves */
			::view-transition-old(*),
			::view-transition-new(*) {
				border-radius: inherit !important;
				overflow: hidden !important;
			}
		</style>
	</head>
	<body class="bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 font-sans transition-colors duration-300">
		<main class="max-w-3xl mx-auto px-4 py-12">
			<a href={backUrl} data-astro-history="back" class="group mb-8 inline-flex items-center text-indigo-600 dark:text-indigo-400 hover:text-indigo-800 dark:hover:text-indigo-300 transition-colors font-medium">
				<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
				</svg>
				{t.back}
			</a>

			<article class="main-card bg-white dark:bg-gray-800 rounded-3xl shadow-xl border border-gray-100 dark:border-gray-700 overflow-hidden">
				<div class="w-full h-64 md:h-80 overflow-hidden bg-gray-200 dark:bg-gray-700">
					<img src={art.data.imagen} alt={art.data.nombre} class="w-full h-full object-cover" transition:name={`img-${art.data.index}`} loading="eager" />
				</div>

				<div class="px-8 pb-12 -mt-8 relative z-10">
					<div class="inner-card bg-white dark:bg-gray-800 rounded-2xl p-8 shadow-lg border border-gray-50 dark:border-gray-700">
						<span class="text-indigo-500 dark:text-indigo-400 font-bold uppercase tracking-widest text-xs">
							{t.label} (REF: #{art.data.index})
						</span>

						<h1 class="text-4xl md:text-5xl font-black text-gray-900 dark:text-white mt-2 mb-6 capitalize" transition:name={`nombre-${art.data.index}`}>
							{art.data.nombre}
						</h1>

						<div class="prose dark:prose-invert max-w-none mb-10">
							<h3 class="text-lg font-semibold text-gray-800 dark:text-gray-200 mb-2 underline decoration-indigo-200 dark:decoration-indigo-900 underline-offset-4">
								{t.about}
							</h3>
							<p class="text-gray-600 dark:text-gray-400 text-xl leading-relaxed whitespace-pre-line">
								{art.data.descripcion || t.defaultDesc}
							</p>
						</div>

						<div class="pt-8 border-t border-gray-100 dark:border-gray-700">
							<a href="tel:676317192" class="inline-flex items-center justify-center w-full bg-green-600 dark:bg-green-700 text-white px-8 py-4 rounded-xl font-bold hover:bg-green-700 dark:hover:bg-green-600 transition-all shadow-lg shadow-green-100 dark:shadow-none active:scale-95 text-lg">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
								</svg>
								{t.call}: 676 317 192
							</a>
						</div>
					</div>
				</div>
			</article>
		</main>
	</body>
</html>
