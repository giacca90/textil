---
import '../styles/global.css';
import {ClientRouter} from 'astro:transitions';

const title = 'Sobre Nosotros | C. PALAU SA';
const description = 'Conoce a C. PALAU SA, especialistas en distribución textil al por mayor con sede en La Roca del Vallès.';
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${baseUrl}/favicon.svg`} />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<ClientRouter />
	</head>
	<body class="bg-gray-50 font-sans text-gray-900 transition-colors duration-300 dark:bg-gray-900 dark:text-gray-100">
		<nav class="sticky top-0 z-50 border-b border-gray-200 bg-white/80 backdrop-blur-md dark:border-gray-800 dark:bg-gray-950/80">
			<div class="mx-auto max-w-6xl px-4 py-4 flex justify-between items-center">
				<a href={`${baseUrl}/`} class="text-xl font-bold text-indigo-600 dark:text-indigo-400">C. PALAU SA</a>
				<a href={`${baseUrl}/`} class="text-sm font-medium hover:text-indigo-600 transition-colors">Volver al Catálogo</a>
			</div>
		</nav>

		<main class="mx-auto max-w-4xl px-4 py-16">
			<header class="mb-12 text-center">
				<h1 class="mb-4 text-5xl font-extrabold tracking-tight text-gray-900 dark:text-white">C. PALAU SA</h1>
				<p class="text-xl text-gray-600 dark:text-gray-400">Especialistas en la distribución mayorista de tejidos.</p>
			</header>

			<section class="space-y-12 text-lg leading-relaxed">
				<div class="rounded-2xl bg-white p-8 shadow-sm border border-gray-100 dark:bg-gray-800 dark:border-gray-700">
					<h2 class="text-2xl font-bold mb-4 text-indigo-600 dark:text-indigo-400">Nuestra Sede</h2>
					<p>
						Ubicados en <strong>La Roca del Vallès</strong>, nos encontramos en un enclave estratégico para la industria textil catalana. Desde nuestras instalaciones coordinamos la logística y distribución de una amplia gama de tejidos para clientes nacionales e internacionales.
					</p>
				</div>

				<div class="rounded-2xl bg-white p-8 shadow-sm border border-gray-100 dark:bg-gray-800 dark:border-gray-700">
					<div class="p-6 border-l-4 border-indigo-500 bg-white shadow-sm dark:bg-gray-800">
						<h3 class="font-bold text-xl mb-2">Experiencia</h3>
						<p class="text-gray-600 dark:text-gray-400 text-base">Décadas de trayectoria en el sector mayorista, garantizando un conocimiento profundo de cada material y proceso textil.</p>
					</div>
					<div class="p-6 border-l-4 border-indigo-500 bg-white shadow-sm dark:bg-gray-800">
						<h3 class="font-bold text-xl mb-2">Compromiso</h3>
						<p class="text-gray-600 dark:text-gray-400 text-base">Servicio enfocado a profesionales, ofreciendo stock constante y soluciones a medida para fabricantes y decoradores.</p>
					</div>
				</div>

				<article class="prose prose-indigo dark:prose-invert max-w-none">
					<h3>Suministro Integral</h3>
					<p>En C. PALAU SA entendemos las exigencias del mercado actual. Por ello, nuestro catálogo abarca desde fibras naturales como el algodón y el lino, hasta tejidos técnicos y de moda, siempre bajo estrictos estándares de calidad.</p>
				</article>
			</section>
		</main>

		<footer class="mt-20 border-t border-gray-200 bg-white py-12 dark:border-gray-800 dark:bg-gray-950 text-center">
			<p class="text-sm text-gray-500">&copy; {new Date().getFullYear()} C. PALAU SA - La Roca del Vallès</p>
		</footer>
	</body>
</html>
