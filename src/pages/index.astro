---
import '../styles/global.css' 
import { getCollection } from 'astro:content';
// Importamos el componente de transiciones
import { ClientRouter } from 'astro:transitions';

const articulos = await getCollection('articulos');
---

<html lang="es">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>Catálogo de Productos</title>
        <ClientRouter />
    </head>
    <body class="bg-gray-50 text-gray-900 font-sans">
        <main class="max-w-6xl mx-auto px-4 py-12">
            <header class="mb-12 text-center">
                <h1 class="text-4xl font-extrabold tracking-tight text-indigo-600 mb-2">
                    Nuestros Productos
                </h1>
            </header>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
                {articulos.map(art => (
                    <article class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden hover:shadow-md transition-shadow duration-300 flex flex-col">
                        <div class="p-6 grow">
                            <div class="flex items-center justify-between mb-4">
                                <span class="text-xs font-semibold uppercase tracking-wider text-indigo-500 bg-indigo-50 px-2 py-1 rounded">
                                    Nuevo
                                </span>
                                <span class="text-gray-400 text-sm">#{art.id}</span>
                            </div>
                            
                            <h2 
                                class="text-xl font-bold text-gray-800 mb-2 capitalize"
                                transition:name={`nombre-${art.id}`}
                            >
                                {art.data.nombre}
                            </h2>
                            
                            <p class="text-gray-600 text-sm leading-relaxed">
                                {art.data.descripcion || "Sin descripción disponible."}
                            </p>
                        </div>
                        
                        <div class="px-6 py-4 bg-gray-50 border-t border-gray-100 mt-auto">
                            <a 
                                href={`/articulo/${art.id}`}
                                class="block text-center w-full bg-indigo-600 text-white py-2 rounded-lg font-medium hover:bg-indigo-700 transition-colors"
                            >
                                Ver detalles
                            </a>
                        </div>
                    </article>
                ))}
            </div>
            
            {articulos.length === 0 && (
                <div class="text-center py-20">
                    <p class="text-gray-500 italic">No se encontraron productos en el archivo CSV.</p>
                </div>
            )}
        </main>
    </body>
</html>