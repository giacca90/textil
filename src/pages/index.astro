---
import '../styles/global.css';
import {ClientRouter} from 'astro:transitions';
import {getCollection, type CollectionEntry} from 'astro:content';

const todosLosArticulos: CollectionEntry<'articulos'>[] = await getCollection('articulos');
const articulos = todosLosArticulos.filter((art) => art.data.lang === 'es');

const lang = 'es'; // Definido para lógica de banderas
const title = 'C Palau S.A. | Mayorista de Tejidos y Telas';
const description = 'Explora nuestro catálogo de tejidos de alta calidad.';
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');

const languages = [
	{code: 'es', label: 'Castellano', flag: 'https://upload.wikimedia.org/wikipedia/commons/9/9a/Flag_of_Spain.svg', path: '/'},
	{code: 'ca', label: 'Català', flag: 'https://upload.wikimedia.org/wikipedia/commons/c/ce/Flag_of_Catalonia.svg', path: '/ca'},
	{code: 'en', label: 'English', flag: 'https://upload.wikimedia.org/wikipedia/commons/a/a5/Flag_of_the_United_Kingdom_%281-2%29.svg', path: '/en'},
	{code: 'fr', label: 'Français', flag: 'https://upload.wikimedia.org/wikipedia/commons/c/c3/Flag_of_France.svg', path: '/fr'},
];
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<ClientRouter />
	</head>
	<body class="bg-gray-50 dark:bg-gray-900 flex flex-col min-h-screen text-gray-900 dark:text-gray-100">
		<main class="mx-auto max-w-6xl px-4 py-12 grow">
			<header class="mb-12 flex flex-col md:flex-row justify-between items-center gap-6">
				<a href={`${baseUrl}/`} class="text-4xl font-extrabold text-indigo-600 dark:text-indigo-400 hover:opacity-80 transition-opacity">C. PALAU SA</a>

				<nav class="flex gap-2 bg-white dark:bg-gray-800 p-1.5 rounded-full shadow-sm border border-gray-200 dark:border-gray-700">
					{
						languages.map((l) => (
							<a href={l.code === 'es' ? `${baseUrl}/` : `${baseUrl}${l.path}`} title={l.label} class={`w-8 h-8 rounded-full border-2 transition-all overflow-hidden ${l.code === lang ? 'border-indigo-500 scale-110' : 'border-transparent opacity-50 hover:opacity-100'}`}>
								<img src={l.flag} alt={l.label} class="w-full h-full object-cover shadow-inner" />
							</a>
						))
					}
				</nav>
			</header>

			<div class="mb-12 text-center">
				<h1 class="text-3xl font-bold mb-8 text-gray-800 dark:text-gray-200">Nuestros Productos</h1>
				<input type="text" id="buscador" placeholder="Buscar tejido..." class="w-full max-w-md mx-auto block rounded-2xl border border-gray-300 p-3 dark:bg-gray-800 dark:border-gray-700 focus:ring-2 focus:ring-indigo-500 outline-none transition-all shadow-sm dark:text-white" transition:persist />
			</div>

			<div id="grid-articulos" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
				{
					articulos.map((art) => (
						<article data-nombre={art.data.nombre.toLowerCase()} class="card-articulo flex flex-col border rounded-xl overflow-hidden bg-white dark:bg-gray-800 shadow-sm hover:shadow-md transition-all dark:border-gray-700">
							<a href={`${baseUrl}/${art.data.lang}/articulo/${art.data.index}`} class="block overflow-hidden aspect-video bg-gray-200 dark:bg-gray-700">
								<img src={art.data.imagen} alt={art.data.nombre} class="object-cover w-full h-full hover:scale-105 transition-transform duration-500" loading="lazy" transition:name={`img-${art.data.index}`} />
							</a>
							<div class="p-6 flex flex-col grow">
								<h2 class="text-xl font-bold mb-2 capitalize">{art.data.nombre}</h2>
								<p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-3 mb-4">{art.data.descripcion}</p>
								<a href={`${baseUrl}/${art.data.lang}/articulo/${art.data.index}`} class="mt-auto block bg-indigo-600 text-white text-center py-2 rounded-lg font-medium hover:bg-indigo-700 transition-colors">
									Ver detalles
								</a>
							</div>
						</article>
					))
				}
			</div>

			<div class="mt-12 text-center">
				<button id="btn-cargar-mas" class="bg-indigo-100 text-indigo-600 dark:bg-indigo-900/40 dark:text-indigo-300 px-8 py-3 rounded-full font-bold hover:bg-indigo-200 transition-all">Cargar más productos</button>
			</div>
			<div id="no-results" class="hidden py-20 text-center italic text-gray-500">No se encontraron tejidos.</div>
		</main>

		<footer class="py-8 border-t border-gray-200 dark:border-gray-800 text-center">
			<p class="text-sm text-gray-500 mb-4">&copy; {new Date().getFullYear()} C. PALAU SA</p>
			<a href={`${baseUrl}/nosotros`} class="text-sm font-medium text-indigo-600 hover:underline">Sobre Nosotros</a>
		</footer>

		<script>
			const setup = () => {
				const input = document.getElementById('buscador') as HTMLInputElement;
				const articles = Array.from(document.querySelectorAll('.card-articulo')) as HTMLElement[];
				const btn = document.getElementById('btn-cargar-mas') as HTMLButtonElement;
				const noRes = document.getElementById('no-results');

				let visible = 15;
				const render = () => {
					const term = input?.value.toLowerCase() || '';
					const filtered = articles.filter((a) => a.dataset.nombre?.includes(term));
					articles.forEach((a) => a.classList.add('hidden'));
					filtered.slice(0, visible).forEach((a) => a.classList.remove('hidden'));
					if (btn) btn.style.display = visible >= filtered.length ? 'none' : 'inline-block';
					noRes?.classList.toggle('hidden', filtered.length > 0);
				};
				input?.addEventListener('input', () => {
					visible = 15;
					render();
				});
				btn?.addEventListener('click', () => {
					visible += 15;
					render();
				});
				render();
			};
			document.addEventListener('astro:page-load', setup);
		</script>
	</body>
</html>
