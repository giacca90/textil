---
import '../styles/global.css';
import {getCollection} from 'astro:content';
import {ClientRouter} from 'astro:transitions';

const articulos = await getCollection('articulos');

const title = 'C Palau S.A. | Mayorista de Tejidos y Telas';
const description = 'Explora nuestro catálogo de tejidos de alta calidad: rasos, lonetas y algodones para profesionales.';
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const canonicalURL = Astro.site ? new URL(Astro.url.pathname, Astro.site) : Astro.url.pathname;
const socialImageURL = Astro.site ? new URL(`${baseUrl}/og-image.jpg`, Astro.site) : `${baseUrl}/og-image.jpg`;
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${baseUrl}/favicon.svg`} />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />

		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={socialImageURL} />

		<ClientRouter />
	</head>
	<body class="bg-gray-50 font-sans text-gray-900 transition-colors duration-300 dark:bg-gray-900 dark:text-gray-100 flex flex-col min-h-screen">
		<main class="mx-auto max-w-6xl px-4 py-12 flex-grow">
			<header class="mb-12 text-center">
				<h1 class="mb-2 text-4xl font-extrabold tracking-tight text-indigo-600 dark:text-indigo-400">Nuestros Productos</h1>

				<div class="relative mx-auto max-w-md mt-8">
					<div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
						<svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
						</svg>
					</div>
					<input type="text" id="buscador" placeholder="Buscar tejido..." class="block w-full rounded-2xl border border-gray-300 bg-white py-3 pr-3 pl-10 leading-5 text-gray-900 placeholder-gray-500 shadow-sm transition-all focus:border-indigo-600 focus:ring-2 focus:ring-indigo-600 focus:outline-none dark:border-gray-700 dark:bg-gray-800 dark:text-white" transition:persist />
				</div>
			</header>

			<div id="grid-articulos" class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
				{
					articulos.map((art) => (
						<article data-nombre={art.data.nombre.toLowerCase()} class="card-articulo hidden flex flex-col overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm transition-all duration-300 hover:shadow-md dark:border-gray-700 dark:bg-gray-800">
							<a href={`${baseUrl}/articulo/${art.id}`} class="group block aspect-video w-full overflow-hidden bg-gray-200 dark:bg-gray-700">
								<img src={art.data.imagen} alt={art.data.nombre} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" transition:name={`img-${art.id}`} />
							</a>

							<div class="flex grow flex-col p-6">
								<h2 class="mb-2 text-xl font-bold text-gray-800 capitalize dark:text-white" transition:name={`nombre-${art.id}`}>
									{art.data.nombre}
								</h2>
								<p class="line-clamp-3 text-sm text-gray-600 dark:text-gray-400">{art.data.descripcion}</p>
							</div>

							<div class="mt-auto border-t border-gray-100 bg-gray-50 px-6 py-4 dark:border-gray-700 dark:bg-gray-800/50">
								<a href={`${baseUrl}/articulo/${art.id}`} class="block w-full rounded-lg bg-indigo-600 py-2 text-center font-medium text-white hover:bg-indigo-700 dark:bg-indigo-500">
									Ver detalles
								</a>
							</div>
						</article>
					))
				}
			</div>

			<div class="mt-12 text-center">
				<button id="btn-cargar-mas" class="rounded-full bg-indigo-100 px-8 py-3 font-semibold text-indigo-600 transition-all hover:bg-indigo-200 dark:bg-indigo-900/30 dark:text-indigo-400">Cargar más productos</button>
			</div>

			<div id="no-results" class="hidden py-20 text-center">
				<p class="text-xl text-gray-500 italic dark:text-gray-400">No se encontraron tejidos.</p>
			</div>
		</main>

		<footer class="mt-auto border-t border-gray-200 bg-white py-8 dark:border-gray-800 dark:bg-gray-950">
			<div class="mx-auto max-w-6xl px-4 flex flex-col md:flex-row justify-between items-center gap-4">
				<p class="text-sm text-gray-500">&copy; {new Date().getFullYear()} C Palau S.A.</p>
				<nav class="flex gap-6">
					<a href={`${baseUrl}/nosotros`} class="text-sm font-medium text-gray-600 hover:text-indigo-600 dark:text-gray-400 dark:hover:text-indigo-400 transition-colors">Sobre Nosotros</a>
				</nav>
			</div>
		</footer>

		<script>
			const setupPagination = () => {
				const input = document.getElementById('buscador') as HTMLInputElement;
				const articles = Array.from(document.querySelectorAll('.card-articulo')) as HTMLElement[];
				const btnCargar = document.getElementById('btn-cargar-mas') as HTMLButtonElement;
				const noResults = document.getElementById('no-results');

				if (!articles.length) return;

				const esMovil = window.innerWidth < 768;
				const articulosPorPagina = esMovil ? 15 : 30;
				let articulosVisibles = articulosPorPagina;

				const render = () => {
					const term = input?.value.toLowerCase() || '';
					const filtrados = articles.filter((art) => art.dataset.nombre?.includes(term));

					articles.forEach((art) => art.classList.add('hidden'));

					const aMostrar = filtrados.slice(0, articulosVisibles);
					aMostrar.forEach((art) => art.classList.remove('hidden'));

					if (btnCargar) {
						btnCargar.style.display = articulosVisibles >= filtrados.length ? 'none' : 'inline-block';
					}

					noResults?.classList.toggle('hidden', filtrados.length > 0);
				};

				input?.addEventListener('input', () => {
					articulosVisibles = articulosPorPagina;
					render();
				});

				btnCargar?.addEventListener('click', () => {
					articulosVisibles += articulosPorPagina;
					render();
				});

				render();
			};

			document.addEventListener('astro:page-load', setupPagination);
		</script>
	</body>
</html>
